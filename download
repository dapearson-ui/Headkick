function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function dst(a, b) { return Math.hypot(a.x - b.x, a.y - b.y); }
function mkHead(side) { return { x: side === "left" ? 180 : GW - 180, y: GROUND - 70, vx: 0, vy: 0, onGround: true, side, facingRight: side === "left", powerCharge: 0, powerFired: false, jumpCount: 0, lastJumpTime: 0, bikeKick: 0, rainbowFlick: 0, rainbowWasHeld: false }; }
function mkBall() { return { x: GW / 2, y: GROUND - 200, vx: (Math.random() - 0.5) * 2, vy: -3, spin: 0 }; }
function mkParticles(x, y, color, n = 18) {
  return Array.from({ length: n }, () => ({ x, y, vx: (Math.random() - 0.5) * 11, vy: Math.random() * -8 - 1, life: 1, decay: 0.022 + Math.random() * 0.018, r: 3 + Math.random() * 5, color }));
}
function initState() {
  return {
    player: mkHead("left"), ai: mkHead("right"), ball: mkBall(),
    score: { p: 0, ai: 0 }, particles: [], phase: "play", goalMsg: "", shake: 0, time: 60,
    stars: Array.from({ length: 40 }, () => ({ x: Math.random() * GW, y: Math.random() * (GROUND - 100), r: 0.5 + Math.random() * 2, a: 0.2 + Math.random() * 0.6 })),
  };
}

// Pre-generate stable crowd data (outside function so it's only done once)
const CROWD_DATA = (() => {
  const rows = [];
  // 5 rows of crowd, each row has many heads
  for (let row = 0; row < 5; row++) {
    const y = 18 + row * 28;
    const headSize = 5 + row * 1.2;
    const spacing = 13 + row * 1.5;
    const count = Math.floor(GW / spacing) + 2;
    const people = [];
    for (let i = 0; i < count; i++) {
      const x = i * spacing + (row % 2 === 0 ? 0 : spacing / 2);
      const skinTones = ["#f5c5a0","#e8a87a","#c87941","#8b5e3c","#4a2e1a","#fde0c0"];
      const shirtColors = [
        "#cc0000","#003399","#f5c842","#ffffff","#ff6b00","#006400",
        "#800080","#ff1493","#00ced1","#dc143c","#1a1a2e","#2e8b57"
      ];
      people.push({
        x, y,
        skin: skinTones[Math.floor(Math.abs(Math.sin(i * row + i) * 6))],
        shirt: shirtColors[Math.floor(Math.abs(Math.sin(i * 7 + row * 3) * 12))],
        armRaise: Math.random() < 0.15, // some arms raised
        armPhase: Math.random() * Math.PI * 2,
        waveSpeed: 0.8 + Math.random() * 1.4,
        size: headSize * (0.85 + Math.random() * 0.3),
        scarf: Math.random() < 0.2,
        scarfColor: shirtColors[Math.floor(Math.random() * 12)],
      });
    }
    rows.push(people);
  }
  return rows;
})();

function drawScene(ctx, s) {
  const t = Date.now();

  // ── Sky gradient (day stadium) ──
  const sky = ctx.createLinearGradient(0, 0, 0, GROUND);
  sky.addColorStop(0, "#1a2a6c");
  sky.addColorStop(0.5, "#b21f1f");
  sky.addColorStop(1, "#fdbb2d");
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, GW, GROUND);

  // ── Stadium upper tier / roof structure ──
  ctx.fillStyle = "#1a1a2e";
  ctx.fillRect(0, 0, GW, 12);
  // Roof overhang shadow
  const roofGrad = ctx.createLinearGradient(0, 12, 0, 24);
  roofGrad.addColorStop(0, "rgba(0,0,0,0.6)");
  roofGrad.addColorStop(1, "rgba(0,0,0,0)");
  ctx.fillStyle = roofGrad;
  ctx.fillRect(0, 12, GW, 12);

  // ── Floodlights ──
  const lightPositions = [60, GW - 60, GW / 2 - 80, GW / 2 + 80];
  lightPositions.forEach(lx => {
    // Pole
    ctx.strokeStyle = "#888"; ctx.lineWidth = 3;
    ctx.beginPath(); ctx.moveTo(lx, 8); ctx.lineTo(lx, 0); ctx.stroke();
    // Light head
    ctx.fillStyle = "#ccc";
    ctx.fillRect(lx - 8, 0, 16, 5);
    // Light glow
    const glow = ctx.createRadialGradient(lx, 5, 0, lx, 5, 40);
    glow.addColorStop(0, "rgba(255,240,200,0.25)");
    glow.addColorStop(1, "rgba(255,240,200,0)");
    ctx.fillStyle = glow;
    ctx.beginPath(); ctx.arc(lx, 5, 40, 0, Math.PI * 2); ctx.fill();
  });

  // ── CROWD ROWS ──
  CROWD_DATA.forEach((row, rowIdx) => {
    // Row background tier
    const tierY = row[0].y - row[0].size - 4;
    const tierH = row[0].size * 2 + 10;
    const tierDark = rowIdx % 2 === 0 ? "rgba(0,0,0,0.25)" : "rgba(0,0,0,0.15)";
    ctx.fillStyle = tierDark;
    ctx.fillRect(0, tierY, GW, tierH);

    row.forEach(p => {
      // Wave animation — crowd does a subtle mexican wave
      const waveOffset = (p.x / GW) * Math.PI * 4;
      const waving = Math.sin(t * 0.001 * p.waveSpeed + waveOffset) > 0.6;
      const bobY = Math.sin(t * 0.002 * p.waveSpeed + p.armPhase) * 1.5;

      const px = p.x, py = p.y + bobY;

      // Body/shirt
      ctx.fillStyle = p.shirt;
      ctx.beginPath();
      ctx.roundRect(px - p.size * 0.7, py - p.size * 0.2, p.size * 1.4, p.size * 1.5, 2);
      ctx.fill();

      // Scarf
      if (p.scarf) {
        ctx.fillStyle = p.scarfColor;
        ctx.fillRect(px - p.size * 0.9, py + p.size * 0.3, p.size * 1.8, p.size * 0.35);
      }

      // Head
      ctx.fillStyle = p.skin;
      ctx.beginPath();
      ctx.arc(px, py - p.size * 0.15, p.size * 0.75, 0, Math.PI * 2);
      ctx.fill();

      // Hair (random dark or light)
      ctx.fillStyle = Math.sin(px + py) > 0 ? "#2a1a0a" : "#8b6914";
      ctx.beginPath();
      ctx.arc(px, py - p.size * 0.4, p.size * 0.72, Math.PI, 0);
      ctx.closePath(); ctx.fill();

      // Arms raised (waving)
      if (waving || p.armRaise) {
        ctx.strokeStyle = p.shirt; ctx.lineWidth = p.size * 0.5; ctx.lineCap = "round";
        ctx.beginPath();
        ctx.moveTo(px - p.size * 0.6, py + p.size * 0.3);
        ctx.lineTo(px - p.size * 1.2, py - p.size * 0.6);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(px + p.size * 0.6, py + p.size * 0.3);
        ctx.lineTo(px + p.size * 1.2, py - p.size * 0.6);
        ctx.stroke();
        // Hands
        ctx.fillStyle = p.skin;
        ctx.beginPath(); ctx.arc(px - p.size * 1.2, py - p.size * 0.65, p.size * 0.35, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.arc(px + p.size * 1.2, py - p.size * 0.65, p.size * 0.35, 0, Math.PI * 2); ctx.fill();
      }
    });
  });

  // ── Advertising boards ──
  const boardY = GROUND - 18;
  const boards = [
    { x: 0,   w: 120, color: "#cc0000", text: "HEADKICK" },
    { x: 130, w: 100, color: "#003399", text: "SPORTS+"  },
    { x: 240, w: 80,  color: "#f5c842", text: "ULTRA"    },
    { x: 330, w: 110, color: "#006400", text: "STADIUM"  },
    { x: 450, w: 90,  color: "#800080", text: "LEAGUE"   },
    { x: 550, w: 120, color: "#cc0000", text: "HEADKICK" },
    { x: 680, w: 120, color: "#003399", text: "LIVE NOW" },
  ];
  boards.forEach(b => {
    ctx.fillStyle = "#000";
    ctx.fillRect(b.x, boardY, b.w, 18);
    ctx.fillStyle = b.color;
    ctx.font = "bold 9px 'Courier New',monospace";
    ctx.textAlign = "center"; ctx.textBaseline = "middle";
    ctx.fillText(b.text, b.x + b.w / 2, boardY + 9);
  });

  // ── Pitch ──
  const pg = ctx.createLinearGradient(0, GROUND, 0, GH);
  pg.addColorStop(0, "#2d7a3a"); pg.addColorStop(1, "#1e5a28");
  ctx.fillStyle = pg; ctx.fillRect(0, GROUND, GW, GH - GROUND);

  // Pitch stripes
  for (let i = 0; i < 8; i++) {
    const sx = i * (GW / 8);
    ctx.fillStyle = i % 2 === 0 ? "rgba(0,0,0,0.08)" : "rgba(255,255,255,0.04)";
    ctx.fillRect(sx, GROUND, GW / 8, GH - GROUND);
  }

  // Pitch lines
  ctx.fillStyle = "rgba(255,255,255,0.08)"; ctx.fillRect(GW / 2 - 1, GROUND, 2, GH - GROUND);
  ctx.beginPath(); ctx.arc(GW / 2, GROUND, 50, 0, Math.PI); ctx.fillStyle = "rgba(255,255,255,0.05)"; ctx.fill();

  // Goals
  function drawGoal(left) {
    const gx = left ? 0 : GW - GOAL_W;
    ctx.fillStyle = "rgba(255,255,255,0.07)"; ctx.fillRect(gx, GROUND - GOAL_H, GOAL_W, GOAL_H);
    ctx.strokeStyle = "#fff"; ctx.lineWidth = 3.5; ctx.strokeRect(gx, GROUND - GOAL_H, GOAL_W, GOAL_H);
    ctx.strokeStyle = "rgba(255,255,255,0.2)"; ctx.lineWidth = 1;
    for (let i = 1; i < 5; i++) { const y2 = GROUND - GOAL_H * i / 5; ctx.beginPath(); ctx.moveTo(gx, y2); ctx.lineTo(gx + GOAL_W, y2); ctx.stroke(); }
    for (let i = 1; i < 3; i++) { const x2 = gx + GOAL_W * i / 2; ctx.beginPath(); ctx.moveTo(x2, GROUND - GOAL_H); ctx.lineTo(x2, GROUND); ctx.stroke(); }
  }
  drawGoal(true); drawGoal(false);
}

function drawBall(ctx, b) {
  ctx.save(); ctx.translate(b.x, b.y); ctx.rotate(b.spin);
  const g = ctx.createRadialGradient(-BALL_R * 0.3, -BALL_R * 0.3, 1, 0, 0, BALL_R);
  g.addColorStop(0, "#fff"); g.addColorStop(1, "#ccc");
  ctx.beginPath(); ctx.arc(0, 0, BALL_R, 0, Math.PI * 2); ctx.fillStyle = g; ctx.fill();
  ctx.fillStyle = "#222";
  [[0, -BALL_R * 0.45], [BALL_R * 0.4, BALL_R * 0.25], [-BALL_R * 0.4, BALL_R * 0.25]].forEach(([bx, by]) => {
    ctx.beginPath(); ctx.arc(bx, by, BALL_R * 0.28, 0, Math.PI * 2); ctx.fill();
  });
  ctx.fillStyle = "rgba(255,255,255,0.55)"; ctx.beginPath(); ctx.arc(-BALL_R * 0.3, -BALL_R * 0.32, BALL_R * 0.18, 0, Math.PI * 2); ctx.fill();
  ctx.restore();
}

// ─── 2D FOOTBALLER DRAWING ──────────────────────────────────────────────
// Player sprite: head sits at h.x, h.y. Full body extends downward.
// Total height ~90px. Collision / kick detection uses HEAD_R around h.x,h.y.

function drawPlayer(ctx, h, isPlayer, kitPrimary, kitSecondary, abbr) {
  const c1  = kitPrimary  || (isPlayer ? "#ffe066" : "#ff4444");
  const c2  = kitSecondary|| (isPlayer ? "#333"    : "#111");
  const dir = h.facingRight ? 1 : -1;
  const isBike = h.bikeKick > 0;

  ctx.save();
  ctx.translate(h.x, h.y);

  // ── BICYCLE KICK POSE ────────────────────────────────────────────────
  if (isBike) {
    // Rotate body ~50° backward (player is flipping)
    const flipProgress = 1 - (h.bikeKick / 40); // 0→1
    const angle = -dir * (Math.PI * 0.55 * flipProgress);
    ctx.rotate(angle);

    // Kicking leg (extended UP and forward)
    ctx.strokeStyle = c2; ctx.lineWidth = 9; ctx.lineCap = "round";
    ctx.beginPath(); ctx.moveTo(dir * 5, 20); ctx.lineTo(dir * 18, -18); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(dir * 18, -18); ctx.lineTo(dir * 28, -42); ctx.stroke();
    // Kicking boot
    ctx.fillStyle = "#1a1a1a";
    ctx.beginPath(); ctx.ellipse(dir * 32, -48, 10, 6, -0.5 * dir, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#333"; ctx.beginPath(); ctx.ellipse(dir * 33, -50, 5, 3, -0.5 * dir, 0, Math.PI * 2); ctx.fill();

    // Trail leg (tucked down)
    ctx.strokeStyle = c2; ctx.lineWidth = 8;
    ctx.beginPath(); ctx.moveTo(-dir * 5, 20); ctx.lineTo(-dir * 8, 46); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(-dir * 8, 46); ctx.lineTo(-dir * 6, 64); ctx.stroke();
    ctx.fillStyle = "#1a1a1a";
    ctx.beginPath(); ctx.ellipse(-dir * 4, 70, 7, 5, 0, 0, Math.PI * 2); ctx.fill();

    // Shorts
    ctx.fillStyle = c2;
    ctx.beginPath(); ctx.ellipse(0, 26, 14, 10, 0, 0, Math.PI * 2); ctx.fill();

    // Body (horizontal)
    ctx.fillStyle = c1;
    ctx.beginPath();
    ctx.moveTo(-16, -6); ctx.lineTo(-14, 28); ctx.lineTo(14, 28); ctx.lineTo(16, -6);
    ctx.quadraticCurveTo(0, -11, -16, -6); ctx.closePath(); ctx.fill();
    ctx.strokeStyle = "rgba(0,0,0,0.2)"; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillStyle = "rgba(0,0,0,0.12)"; ctx.fillRect(-3, -4, 6, 30);

    // Arms spread for balance
    ctx.strokeStyle = c1; ctx.lineWidth = 7; ctx.lineCap = "round";
    ctx.beginPath(); ctx.moveTo(-14, 4); ctx.lineTo(-30, 18); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(14, 4); ctx.lineTo(30, 18); ctx.stroke();
    ctx.fillStyle = "#f0d0a0";
    ctx.beginPath(); ctx.arc(-32, 20, 4, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(32, 20, 4, 0, Math.PI * 2); ctx.fill();

    // Collar + neck
    ctx.fillStyle = c2; ctx.beginPath(); ctx.ellipse(0, -7, 6, 4, 0, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#f0d0a0"; ctx.beginPath(); ctx.ellipse(0, -8, 5, 3.5, 0, 0, Math.PI * 2); ctx.fill();
    ctx.fillRect(-4, -14, 8, 10);

    // Head (same as normal)
    const skinG = ctx.createRadialGradient(-6, -28, 3, 0, -24, HEAD_R);
    skinG.addColorStop(0, "#fce0b8"); skinG.addColorStop(1, "#e8b87a");
    ctx.beginPath(); ctx.arc(0, -24, HEAD_R, 0, Math.PI * 2);
    ctx.fillStyle = skinG; ctx.fill();
    ctx.strokeStyle = "#c8985a"; ctx.lineWidth = 1.5; ctx.stroke();
    ctx.fillStyle = isPlayer ? "#2a1800" : "#8b0000";
    ctx.beginPath(); ctx.arc(0, -24, HEAD_R, Math.PI, 0); ctx.closePath(); ctx.fill();
    ctx.fillStyle = "#fff";
    ctx.beginPath(); ctx.ellipse(-7, -26, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(7, -26, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#1a1a1a";
    ctx.beginPath(); ctx.arc(-7 + dir, -26, 2.5, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(7 + dir, -26, 2.5, 0, Math.PI * 2); ctx.fill();
    // Gritted teeth expression
    ctx.strokeStyle = "#8b4513"; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(-5, -18); ctx.lineTo(5, -18); ctx.stroke();

    ctx.restore();
    // Nameplate
    ctx.save(); ctx.translate(h.x, h.y + 80);
    ctx.fillStyle = c1; ctx.strokeStyle = "rgba(0,0,0,0.5)"; ctx.lineWidth = 2;
    ctx.font = "bold 10px 'Courier New',monospace"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
    ctx.strokeText(abbr || (isPlayer ? "YOU" : "CPU"), 0, 0);
    ctx.fillText(abbr || (isPlayer ? "YOU" : "CPU"), 0, 0);
    ctx.restore();
    return;
  }

  // ── NORMAL POSE ──────────────────────────────────────────────────────
  const isRainbow = h.rainbowFlick > 0;
  const runPhase = (Date.now() * 0.012) * dir;
  const legSway  = h.onGround ? Math.sin(runPhase) * (Math.abs(h.vx) > 0.5 ? 6 : 0) : 0;

  if (isRainbow) {
    // Rainbow flick pose: both heels raised backward, one leg kicking up behind
    ctx.strokeStyle = c2; ctx.lineWidth = 9; ctx.lineCap = "round";
    // Plant leg straight
    ctx.beginPath(); ctx.moveTo(-dir * 5, 32); ctx.lineTo(-dir * 7, 62); ctx.stroke();
    // Kicking heel leg — swings UP and BACK
    ctx.beginPath(); ctx.moveTo(dir * 5, 32); ctx.lineTo(dir * 10, 18); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(dir * 10, 18); ctx.lineTo(dir * 5, 0); ctx.stroke();
    // Socks
    ctx.strokeStyle = "#fff"; ctx.lineWidth = 7;
    ctx.beginPath(); ctx.moveTo(-dir * 7, 60); ctx.lineTo(-dir * 7, 68); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(dir * 5, 0); ctx.lineTo(dir * 4, -6); ctx.stroke();
    // Boots
    ctx.fillStyle = "#1a1a1a";
    ctx.beginPath(); ctx.ellipse(-dir * 5, 72, 8, 5, 0, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(dir * 3, -10, 8, 5, -0.6 * dir, 0, Math.PI * 2); ctx.fill();
    // Purple glow trail
    ctx.save();
    ctx.globalAlpha = 0.5;
    ctx.strokeStyle = "#a855f7"; ctx.lineWidth = 14; ctx.lineCap = "round";
    ctx.beginPath(); ctx.moveTo(dir * 5, 32); ctx.lineTo(dir * 3, -10); ctx.stroke();
    ctx.globalAlpha = 1;
    ctx.restore();
  } else {
  // Thighs
  ctx.strokeStyle = c2; ctx.lineWidth = 9; ctx.lineCap = "round";
  // Left thigh
  ctx.beginPath(); ctx.moveTo(-7, 32); ctx.lineTo(-9 + legSway, 54); ctx.stroke();
  // Right thigh
  ctx.beginPath(); ctx.moveTo(7, 32); ctx.lineTo(9 - legSway, 54); ctx.stroke();

  // Socks (white strip at bottom of shin)
  ctx.strokeStyle = "#fff"; ctx.lineWidth = 7;
  ctx.beginPath(); ctx.moveTo(-9 + legSway, 60); ctx.lineTo(-9 + legSway, 68); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(9 - legSway, 60); ctx.lineTo(9 - legSway, 68); ctx.stroke();

  // Shins (kit secondary colour)
  ctx.strokeStyle = c2; ctx.lineWidth = 7;
  ctx.beginPath(); ctx.moveTo(-9 + legSway, 54); ctx.lineTo(-9 + legSway, 62); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(9 - legSway, 54); ctx.lineTo(9 - legSway, 62); ctx.stroke();

  // Boots
  ctx.fillStyle = "#1a1a1a";
  ctx.beginPath(); ctx.ellipse(-9 + legSway + dir * 3, 70, 8, 5, 0, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(9 - legSway + dir * 3, 70, 8, 5, 0, 0, Math.PI * 2); ctx.fill();
  // Boot highlight
  ctx.fillStyle = "#333";
  ctx.beginPath(); ctx.ellipse(-9 + legSway + dir * 4, 68, 4, 2.5, 0, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(9 - legSway + dir * 4, 68, 4, 2.5, 0, 0, Math.PI * 2); ctx.fill();
  }

  // Shorts
  ctx.fillStyle = c2;
  ctx.beginPath();
  ctx.moveTo(-13, 28); ctx.lineTo(13, 28);
  ctx.lineTo(13, 42); ctx.lineTo(0, 44); ctx.lineTo(-13, 42);
  ctx.closePath(); ctx.fill();
  // Shorts trim line
  ctx.strokeStyle = "rgba(255,255,255,0.2)"; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(-13, 34); ctx.lineTo(13, 34); ctx.stroke();

  // ── Body / Jersey ──
  // Torso shape
  ctx.fillStyle = c1;
  ctx.beginPath();
  ctx.moveTo(-14, -4);   // shoulder left
  ctx.lineTo(-12, 30);   // hip left
  ctx.lineTo(12,  30);   // hip right
  ctx.lineTo(14,  -4);   // shoulder right
  ctx.quadraticCurveTo(0, -9, -14, -4); // collar curve
  ctx.closePath(); ctx.fill();
  ctx.strokeStyle = "rgba(0,0,0,0.25)"; ctx.lineWidth = 1; ctx.stroke();

  // Jersey vertical stripe / panel
  ctx.fillStyle = "rgba(0,0,0,0.12)";
  ctx.fillRect(-3, -2, 6, 32);

  // Collar
  ctx.fillStyle = c2;
  ctx.beginPath(); ctx.ellipse(0, -5, 6, 4, 0, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = "#f0d0a0";
  ctx.beginPath(); ctx.ellipse(0, -6, 5, 3.5, 0, 0, Math.PI * 2); ctx.fill();

  // Shirt number on back/front
  ctx.fillStyle = c2 === "#fff" || c2 === "#FFFFFF" ? "#000" : "#fff";
  ctx.font = "bold 9px 'Courier New',monospace"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
  ctx.fillText(isPlayer ? "10" : "9", 0, 16);

  // Arms
  const armSway = h.onGround ? Math.sin(runPhase + Math.PI) * (Math.abs(h.vx) > 0.5 ? 5 : 0) : 2;
  ctx.strokeStyle = c1; ctx.lineWidth = 7; ctx.lineCap = "round";
  // Left arm
  ctx.beginPath(); ctx.moveTo(-13, 0); ctx.lineTo(-20 - armSway, 18); ctx.stroke();
  // Right arm
  ctx.beginPath(); ctx.moveTo(13, 0); ctx.lineTo(20 + armSway, 18); ctx.stroke();
  // Hands
  ctx.fillStyle = "#f0d0a0";
  ctx.beginPath(); ctx.arc(-20 - armSway, 20, 4, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(20 + armSway, 20, 4, 0, Math.PI * 2); ctx.fill();

  // ── Neck ──
  ctx.fillStyle = "#f0d0a0";
  ctx.fillRect(-4, -12, 8, 10);

  // ── Head ──
  // Head shadow
  ctx.fillStyle = "rgba(0,0,0,0.15)";
  ctx.beginPath(); ctx.ellipse(2, -22, HEAD_R - 2, HEAD_R - 2, 0, 0, Math.PI * 2); ctx.fill();
  // Skin
  const skinG = ctx.createRadialGradient(-6, -28, 3, 0, -24, HEAD_R);
  skinG.addColorStop(0, "#fce0b8"); skinG.addColorStop(1, "#e8b87a");
  ctx.beginPath(); ctx.arc(0, -24, HEAD_R, 0, Math.PI * 2);
  ctx.fillStyle = skinG; ctx.fill();
  ctx.strokeStyle = "#c8985a"; ctx.lineWidth = 1.5; ctx.stroke();

  // Hair (short on top)
  ctx.fillStyle = isPlayer ? "#2a1800" : "#8b0000";
  ctx.beginPath();
  ctx.arc(0, -24, HEAD_R, Math.PI, 0);  // top half arc
  ctx.closePath(); ctx.fill();
  // Hair detail lines
  ctx.strokeStyle = isPlayer ? "#3d2500" : "#600000"; ctx.lineWidth = 1;
  for (let i = -3; i <= 3; i++) {
    ctx.beginPath();
    ctx.moveTo(i * 5, -24 - HEAD_R * 0.6);
    ctx.lineTo(i * 4, -24 - HEAD_R * 0.1);
    ctx.stroke();
  }

  // Ears
  ctx.fillStyle = "#f0d0a0";
  ctx.beginPath(); ctx.ellipse(-HEAD_R + 1, -22, 5, 7, 0.2, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(HEAD_R - 1, -22, 5, 7, -0.2, 0, Math.PI * 2); ctx.fill();
  ctx.strokeStyle = "#c8985a"; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.ellipse(-HEAD_R + 1, -22, 3, 5, 0.2, 0, Math.PI * 2); ctx.stroke();
  ctx.beginPath(); ctx.ellipse(HEAD_R - 1, -22, 3, 5, -0.2, 0, Math.PI * 2); ctx.stroke();

  // Eyebrows
  ctx.strokeStyle = isPlayer ? "#2a1800" : "#5a0000"; ctx.lineWidth = 2; ctx.lineCap = "round";
  ctx.beginPath(); ctx.moveTo(-10, -30); ctx.lineTo(-4, -31); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(4, -31); ctx.lineTo(10, -30); ctx.stroke();

  // Eyes
  ctx.fillStyle = "#fff";
  ctx.beginPath(); ctx.ellipse(-7, -26, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(7, -26, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
  // Pupils (look in direction of travel)
  const eyeOff = dir * 1.5;
  ctx.fillStyle = "#1a1a1a";
  ctx.beginPath(); ctx.arc(-7 + eyeOff, -26, 2.5, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(7 + eyeOff, -26, 2.5, 0, Math.PI * 2); ctx.fill();
  // Eye shine
  ctx.fillStyle = "#fff";
  ctx.beginPath(); ctx.arc(-6 + eyeOff, -27, 1, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(8 + eyeOff, -27, 1, 0, Math.PI * 2); ctx.fill();

  // Nose
  ctx.strokeStyle = "#c8985a"; ctx.lineWidth = 1.5; ctx.lineCap = "round";
  ctx.beginPath(); ctx.moveTo(2, -24); ctx.quadraticCurveTo(5, -20, 2, -18); ctx.stroke();

  // Mouth — smile or determined based on score
  ctx.strokeStyle = "#8b4513"; ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(0, -19, 5, 0.1 * Math.PI, 0.9 * Math.PI); ctx.stroke();

  // Team abbr nameplate below feet
  ctx.restore();
  ctx.save();
  ctx.translate(h.x, h.y + 78);
  ctx.fillStyle = c1;
  ctx.strokeStyle = "rgba(0,0,0,0.5)"; ctx.lineWidth = 2;
  const tag = abbr || (isPlayer ? "YOU" : "CPU");
  ctx.font = "bold 10px 'Courier New',monospace"; ctx.textAlign = "center"; ctx.textBaseline = "middle";
  ctx.strokeText(tag, 0, 0); ctx.fillText(tag, 0, 0);
  ctx.restore();
}

function drawParticles(ctx, particles) {
  particles.forEach(p => { ctx.globalAlpha = p.life; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.r * p.life, 0, Math.PI * 2); ctx.fill(); });
  ctx.globalAlpha = 1;
}

