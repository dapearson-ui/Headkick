const BADGE_OPTIONS = ["⚽","🦁","🐯","🦅","🔥","⚡","🌙","💎","🐉","🦊","🐺","🌟","🛡️","⚔️","🏴‍☠️","🦄","🐻","🦈","🌊","🏔️"];
const KIT_COLORS = [
  { label:"Red",    primary:"#cc0000", secondary:"#fff"    },
  { label:"Blue",   primary:"#003399", secondary:"#fff"    },
  { label:"Green",  primary:"#006400", secondary:"#fff"    },
  { label:"Black",  primary:"#111",    secondary:"#f5c842" },
  { label:"White",  primary:"#eee",    secondary:"#111"    },
  { label:"Purple", primary:"#5b0eae", secondary:"#fff"    },
  { label:"Orange", primary:"#e65c00", secondary:"#fff"    },
  { label:"Yellow", primary:"#f5c842", secondary:"#111"    },
  { label:"Navy",   primary:"#001f5b", secondary:"#c0a020" },
  { label:"Maroon", primary:"#7b0000", secondary:"#fff"    },
];

const DEFAULT_PLAYERS = POSITIONS.map((pos, i) => ({
  id: i, pos,
  name: ["Hart","Walker","Stones","Silva","Shaw","Rodri","De Bruyne","Saka","Bernardo","Foden","Haaland"][i],
  rating: [82,84,85,87,83,89,91,87,88,88,92][i],
}));

// Pitch coords as [x%, y%] — origin top-left, attack goes upward (ST at top)
// 4-2-3-1: GK(bottom), RB CB CB LB, CM CM, RW CAM LW, ST(top)
const PITCH_POS = [
  [50, 88],          // GK
  [82, 70],          // RB
  [62, 70],          // CB
  [38, 70],          // CB
  [18, 70],          // LB
  [62, 50],          // CM
  [38, 50],          // CM
  [82, 30],          // RW
  [50, 30],          // CAM
  [18, 30],          // LW
  [50, 12],          // ST
];

function StarRating({ val, max = 5 }) {
  const full = Math.round((val / 99) * max);
  return (
    <span style={{ letterSpacing: 1 }}>
      {Array.from({ length: max }, (_, i) => (
        <span key={i} style={{ color: i < full ? "#f5c842" : "#333", fontSize: 12 }}>★</span>
      ))}
    </span>
  );
}

function KitSvg({ primary, secondary, size = 48 }) {
  return (
    <svg width={size} height={size} viewBox="0 0 48 48" style={{ flexShrink: 0 }}>
      {/* shirt body */}
      <path d="M14 12 L8 20 L14 22 L14 40 L34 40 L34 22 L40 20 L34 12 L28 8 Q24 11 20 8 Z" fill={primary} stroke={secondary} strokeWidth="1.5"/>
      {/* collar */}
      <path d="M20 8 Q24 13 28 8" fill="none" stroke={secondary} strokeWidth="1.5"/>
      {/* sleeve stripe */}
      <line x1="8" y1="20" x2="14" y2="22" stroke={secondary} strokeWidth="2"/>
      <line x1="40" y1="20" x2="34" y2="22" stroke={secondary} strokeWidth="2"/>
    </svg>
  );
}

function MyTeamPanel() {
  const [subTab, setSubTab] = useState("kit");
  const [teamName, setTeamName] = useState("My FC");
  const [badge, setBadge] = useState("🦁");
  const [kit, setKit] = useState(KIT_COLORS[0]);
  const [players, setPlayers] = useState(DEFAULT_PLAYERS);
  const [editingPlayer, setEditingPlayer] = useState(null);
  const [editName, setEditName] = useState("");
  const [editRating, setEditRating] = useState(80);
  const [saved, setSaved] = useState(false);

  const avgRating = Math.round(players.reduce((s, p) => s + p.rating, 0) / players.length);
  const overallStars = Math.round((avgRating / 99) * 5);
  const attack = Math.round(players.filter(p => ["ST","LW","RW"].includes(p.pos)).reduce((s,p) => s+p.rating,0) / 3);
  const midfield = Math.round(players.filter(p => ["CM","CAM"].includes(p.pos)).reduce((s,p) => s+p.rating,0) / 3);
  const defence = Math.round(players.filter(p => ["CB","LB","RB","GK"].includes(p.pos)).reduce((s,p) => s+p.rating,0) / 5);

  function openEdit(p) { setEditingPlayer(p.id); setEditName(p.name); setEditRating(p.rating); }
  function saveEdit() {
    setPlayers(ps => ps.map(p => p.id === editingPlayer ? { ...p, name: editName, rating: editRating } : p));
    setEditingPlayer(null);
  }
  function handleSave() { setSaved(true); setTimeout(() => setSaved(false), 2000); }

  // formation positions defined globally above

  return (
    <div>
      {/* Edit player modal */}
      {editingPlayer !== null && (
        <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.85)", zIndex:1000, display:"flex", alignItems:"center", justifyContent:"center" }}
          onClick={e => e.target===e.currentTarget && setEditingPlayer(null)}>
          <div style={{ background:"#0c0c1e", border:"2px solid #f5c84244", borderRadius:12, padding:28, width:300 }}>
            <div style={{ fontFamily:"Oswald,sans-serif", fontSize:18, color:"#f5c842", marginBottom:18, letterSpacing:2 }}>EDIT PLAYER</div>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:12, color:"#555", letterSpacing:2, marginBottom:6 }}>NAME</div>
            <input value={editName} onChange={e => setEditName(e.target.value)}
              style={{ width:"100%", background:"#07070e", border:"1px solid #f5c84244", borderRadius:6, padding:"9px 12px", color:"#eee", fontFamily:"Barlow Condensed,sans-serif", fontSize:16, marginBottom:16, outline:"none" }} />
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:12, color:"#555", letterSpacing:2, marginBottom:6 }}>RATING: <span style={{ color:"#f5c842", fontWeight:700 }}>{editRating}</span></div>
            <input type="range" min={50} max={99} value={editRating} onChange={e => setEditRating(+e.target.value)}
              style={{ width:"100%", marginBottom:20, accentColor:"#f5c842" }} />
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={() => setEditingPlayer(null)} style={{ flex:1, padding:"9px", background:"transparent", border:"1px solid #333", borderRadius:6, color:"#666", fontFamily:"Oswald,sans-serif", cursor:"pointer" }}>Cancel</button>
              <button onClick={saveEdit} style={{ flex:2, padding:"9px", background:"#f5c842", border:"none", borderRadius:6, color:"#06060f", fontFamily:"Oswald,sans-serif", fontSize:15, fontWeight:700, cursor:"pointer" }}>Save</button>
            </div>
          </div>
        </div>
      )}

      {/* Header card */}
      <div style={{ background:`linear-gradient(135deg,${kit.primary}88,#0c0c1e)`, border:`2px solid ${kit.primary}66`, borderRadius:10, padding:"16px 20px", marginBottom:16, display:"flex", alignItems:"center", gap:16 }}>
        <div style={{ fontSize:44, width:48, height:48, display:"flex", alignItems:"center", justifyContent:"center" }}>
          {SVG_BADGES[badge] ? SVG_BADGES[badge]({ size: 48 }) : badge}
        </div>
        <KitSvg primary={kit.primary} secondary={kit.secondary} size={52} />
        <div style={{ flex:1 }}>
          <div style={{ fontSize:28, fontWeight:700, letterSpacing:3, color:"#fff" }}>{teamName}</div>
          <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:13, color:"rgba(255,255,255,0.4)", marginTop:2 }}>
            OVR {avgRating} · {Array.from({length:5},(_,i)=><span key={i} style={{color:i<overallStars?"#f5c842":"#333"}}>★</span>)}
          </div>
        </div>
        <button onClick={handleSave} style={{ background: saved?"#3ecf5a":"#f5c842", border:"none", borderRadius:6, padding:"10px 20px", fontFamily:"Oswald,sans-serif", fontSize:14, fontWeight:700, color:"#06060f", cursor:"pointer", letterSpacing:1, transition:"background .3s" }}>
          {saved ? "✓ SAVED!" : "💾 SAVE"}
        </button>
      </div>

      {/* Sub tabs */}
      <div style={{ display:"flex", gap:6, marginBottom:14 }}>
        {[["kit","🎨 Kit & Badge"],["squad","👕 Squad"],["formation","🏟️ Formation"],["stats","📊 Club Stats"]].map(([t,l]) => (
          <button key={t} onClick={() => setSubTab(t)} style={{ fontFamily:"Oswald,sans-serif", fontSize:13, letterSpacing:1, padding:"7px 16px", borderRadius:4, cursor:"pointer", background:subTab===t?"#1a1a3e":"#0c0c1e", color:subTab===t?"#f5c842":"#555", border:`1px solid ${subTab===t?"#f5c842":"#1a1a3e"}` }}>{l}</button>
        ))}
      </div>

      {/* KIT & BADGE */}
      {subTab === "kit" && (
        <div style={{ display:"flex", flexDirection:"column", gap:16 }}>
          <div style={{ background:"#0c0c1e", borderRadius:8, padding:18, border:"1px solid #1a1a3e" }}>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:3, marginBottom:12 }}>CLUB NAME</div>
            <input value={teamName} onChange={e => setTeamName(e.target.value)} maxLength={24}
              style={{ width:"100%", background:"#07070e", border:"1px solid #f5c84233", borderRadius:6, padding:"10px 14px", color:"#eee", fontFamily:"Oswald,sans-serif", fontSize:20, letterSpacing:2, outline:"none" }} />
          </div>

          <div style={{ background:"#0c0c1e", borderRadius:8, padding:18, border:"1px solid #1a1a3e" }}>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:3, marginBottom:12 }}>BADGE</div>
            <div style={{ display:"flex", flexWrap:"wrap", gap:8 }}>
              {/* SVG badges first */}
              {Object.entries(SVG_BADGES).map(([key, BadgeComp]) => (
                <button key={key} onClick={() => setBadge(key)} title="Liver Bird" style={{ width:52, height:52, display:"flex", alignItems:"center", justifyContent:"center", borderRadius:8, cursor:"pointer", background:badge===key?"#1a1a3e":"#07070e", border:`2px solid ${badge===key?"#f5c842":"#1a1a3e"}`, transition:"all .15s", padding:4 }}>
                  <BadgeComp size={36} />
                </button>
              ))}
              {/* Emoji badges */}
              {BADGE_OPTIONS.map(b => (
                <button key={b} onClick={() => setBadge(b)} style={{ fontSize:28, padding:"6px 10px", borderRadius:8, cursor:"pointer", background:badge===b?"#1a1a3e":"#07070e", border:`2px solid ${badge===b?"#f5c842":"#1a1a3e"}`, transition:"all .15s" }}>{b}</button>
              ))}
            </div>
          </div>

          <div style={{ background:"#0c0c1e", borderRadius:8, padding:18, border:"1px solid #1a1a3e" }}>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:3, marginBottom:12 }}>KIT COLOUR</div>
            <div style={{ display:"flex", flexWrap:"wrap", gap:10 }}>
              {KIT_COLORS.map(c => (
                <button key={c.label} onClick={() => setKit(c)} style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:5, padding:"8px 10px", borderRadius:8, cursor:"pointer", background:kit.label===c.label?"#1a1a3e":"#07070e", border:`2px solid ${kit.label===c.label?"#f5c842":"#1a1a3e"}`, transition:"all .15s" }}>
                  <KitSvg primary={c.primary} secondary={c.secondary} size={40} />
                  <span style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:kit.label===c.label?"#f5c842":"#555" }}>{c.label}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* SQUAD */}
      {subTab === "squad" && (
        <div style={{ background:"#0c0c1e", borderRadius:8, border:"1px solid #1a1a3e", overflow:"hidden" }}>
          <div style={{ display:"grid", gridTemplateColumns:"32px 60px 1fr 70px 60px", padding:"8px 14px", borderBottom:"1px solid #1a1a3e" }}>
            {["#","POS","NAME","RATING",""].map(h => <div key={h} style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:1 }}>{h}</div>)}
          </div>
          {players.map((p, i) => {
            const rColor = p.rating >= 88 ? "#f5c842" : p.rating >= 80 ? "#3ecf5a" : p.rating >= 70 ? "#888" : "#ff6b6b";
            return (
              <div key={p.id} style={{ display:"grid", gridTemplateColumns:"32px 60px 1fr 70px 60px", padding:"10px 14px", borderBottom:"1px solid #0f0f1f", background:i%2===0?"transparent":"rgba(255,255,255,0.01)", alignItems:"center", animation:`fadeIn .15s ${i*.03}s both` }}>
                <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:13, color:"#444" }}>{i+1}</div>
                <div style={{ background:`${kit.primary}33`, border:`1px solid ${kit.primary}66`, borderRadius:4, padding:"2px 6px", fontFamily:"Oswald,sans-serif", fontSize:11, color:kit.primary==="eee"?"#111":kit.primary, textAlign:"center", width:"fit-content" }}>{p.pos}</div>
                <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:16, color:"#eee" }}>{p.name}</div>
                <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                  <span style={{ fontFamily:"Oswald,sans-serif", fontSize:20, fontWeight:700, color:rColor }}>{p.rating}</span>
                  <StarRating val={p.rating} />
                </div>
                <button onClick={() => openEdit(p)} style={{ background:"transparent", border:"1px solid #f5c84244", color:"#f5c842", fontFamily:"Barlow Condensed,sans-serif", fontSize:13, padding:"4px 10px", borderRadius:4, cursor:"pointer" }}>✏️</button>
              </div>
            );
          })}
        </div>
      )}

      {/* FORMATION */}
      {subTab === "formation" && (
        <div style={{ background:"#0c0c1e", borderRadius:8, border:"1px solid #1a1a3e", padding:16 }}>
          <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:3, marginBottom:12 }}>4-2-3-1 FORMATION</div>
          <div style={{ position:"relative", width:"100%", paddingBottom:"62%", background:"linear-gradient(180deg,#1a5c28 0%,#1e6a2e 48%,#1a5c28 100%)", borderRadius:8, overflow:"hidden", border:"2px solid rgba(255,255,255,0.08)" }}>
            {/* Pitch markings */}
            <svg style={{ position:"absolute", inset:0, width:"100%", height:"100%" }} viewBox="0 0 100 62" preserveAspectRatio="none">
              <line x1="50" y1="0" x2="50" y2="62" stroke="rgba(255,255,255,0.12)" strokeWidth="0.3"/>
              <circle cx="50" cy="31" r="10" fill="none" stroke="rgba(255,255,255,0.12)" strokeWidth="0.3"/>
              <rect x="20" y="18" width="60" height="26" fill="none" stroke="rgba(255,255,255,0.12)" strokeWidth="0.3"/>
              <rect x="35" y="24" width="30" height="14" fill="none" stroke="rgba(255,255,255,0.12)" strokeWidth="0.3"/>
              <rect x="0" y="22" width="8" height="18" fill="none" stroke="rgba(255,255,255,0.12)" strokeWidth="0.3"/>
              <rect x="92" y="22" width="8" height="18" fill="none" stroke="rgba(255,255,255,0.12)" strokeWidth="0.3"/>
            </svg>
            {players.map((p, i) => {
              const [px, py] = PITCH_POS[i] || [50, 50];
              const rColor = p.rating >= 88 ? "#f5c842" : p.rating >= 80 ? "#3ecf5a" : "#888";
              return (
                <div key={p.id} onClick={() => openEdit(p)} style={{ position:"absolute", left:`${px}%`, top:`${py}%`, transform:"translate(-50%,-50%)", display:"flex", flexDirection:"column", alignItems:"center", gap:3, cursor:"pointer" }}>
                  <div style={{ width:34, height:34, borderRadius:"50%", background:kit.primary, border:`2px solid ${kit.secondary}`, display:"flex", alignItems:"center", justifyContent:"center", fontFamily:"Oswald,sans-serif", fontSize:13, fontWeight:700, color:kit.secondary, boxShadow:`0 0 10px ${kit.primary}88` }}>
                    {p.rating}
                  </div>
                  <div style={{ background:"rgba(0,0,0,0.75)", borderRadius:3, padding:"1px 5px", fontFamily:"Barlow Condensed,sans-serif", fontSize:10, color:"#fff", whiteSpace:"nowrap", maxWidth:60, overflow:"hidden", textOverflow:"ellipsis" }}>{p.name}</div>
                  <div style={{ fontFamily:"Oswald,sans-serif", fontSize:9, color:rColor }}>{p.pos}</div>
                </div>
              );
            })}
          </div>
          <div style={{ marginTop:10, fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#444", textAlign:"center" }}>👆 Tap any player to edit</div>
        </div>
      )}

      {/* STATS */}
      {subTab === "stats" && (
        <div style={{ display:"flex", flexDirection:"column", gap:12 }}>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:10 }}>
            {[["⚔️ Attack", attack, "#ff6b6b"], ["⚙️ Midfield", midfield, "#f5c842"], ["🛡️ Defence", defence, "#3ecf5a"]].map(([lbl,val,col]) => (
              <div key={lbl} style={{ background:"#0c0c1e", borderRadius:8, padding:"16px 12px", textAlign:"center", border:`1px solid ${col}33` }}>
                <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:13, color:"#666", marginBottom:6 }}>{lbl}</div>
                <div style={{ fontFamily:"Oswald,sans-serif", fontSize:36, fontWeight:700, color:col }}>{val}</div>
                <StarRating val={val} />
              </div>
            ))}
          </div>

          <div style={{ background:"#0c0c1e", borderRadius:8, padding:18, border:"1px solid #1a1a3e" }}>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:3, marginBottom:14 }}>SQUAD RATINGS BREAKDOWN</div>
            {players.map((p, i) => {
              const pct = ((p.rating - 50) / 49) * 100;
              const rColor = p.rating >= 88 ? "#f5c842" : p.rating >= 80 ? "#3ecf5a" : p.rating >= 70 ? "#888" : "#ff6b6b";
              return (
                <div key={p.id} style={{ display:"flex", alignItems:"center", gap:10, marginBottom:8, animation:`fadeIn .15s ${i*.03}s both` }}>
                  <div style={{ width:32, fontFamily:"Oswald,sans-serif", fontSize:10, color:"#444", textAlign:"right", flexShrink:0 }}>{p.pos}</div>
                  <div style={{ width:100, fontFamily:"Barlow Condensed,sans-serif", fontSize:13, color:"#eee", flexShrink:0, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{p.name}</div>
                  <div style={{ flex:1, height:8, background:"#07070e", borderRadius:4, overflow:"hidden" }}>
                    <div style={{ width:`${pct}%`, height:"100%", background:rColor, borderRadius:4, transition:"width .4s ease" }} />
                  </div>
                  <div style={{ width:28, fontFamily:"Oswald,sans-serif", fontSize:14, fontWeight:700, color:rColor, textAlign:"right", flexShrink:0 }}>{p.rating}</div>
                </div>
              );
            })}
          </div>

          <div style={{ background:"#0c0c1e", borderRadius:8, padding:18, border:"1px solid #1a1a3e" }}>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", letterSpacing:3, marginBottom:14 }}>TEAM OVERVIEW</div>
            <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
              {[
                ["Overall Rating", avgRating, "#f5c842"],
                ["Best Player", players.reduce((a,b)=>a.rating>b.rating?a:b).name, "#f5c842"],
                ["Top Rated Pos", players.reduce((a,b)=>a.rating>b.rating?a:b).pos, "#888"],
                ["Squad Size", players.length + " players", "#888"],
                ["World Class (90+)", players.filter(p=>p.rating>=90).length, "#f5c842"],
                ["Gold (80-89)", players.filter(p=>p.rating>=80&&p.rating<90).length, "#3ecf5a"],
              ].map(([lbl,val,col]) => (
                <div key={lbl} style={{ background:"#07070e", borderRadius:6, padding:"10px 14px" }}>
                  <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:11, color:"#555", marginBottom:4 }}>{lbl}</div>
                  <div style={{ fontFamily:"Oswald,sans-serif", fontSize:18, color:col, fontWeight:700 }}>{val}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
