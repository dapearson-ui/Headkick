            {DIFFICULTIES.map(d => (
              <button key={d.id} onClick={() => setDifficulty(d)}
                style={{ padding:"12px 8px", borderRadius:8, cursor:"pointer", background:difficulty.id===d.id?`${d.color}22`:"#07070e", border:`2px solid ${difficulty.id===d.id?d.color:"#1a1a3e"}`, transition:"all .15s", textAlign:"center", gridColumn: d.id==="notsmart" ? "1 / -1" : "auto" }}>
                <div style={{ fontFamily:"Oswald,sans-serif", fontSize: d.id==="notsmart"?15:13, fontWeight:700, color:difficulty.id===d.id?d.color:"#555", letterSpacing:1 }}>{d.label}</div>
                <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:10, color:"#444", marginTop:4 }}>{d.desc}</div>
              </button>
            ))}
          </div>
        </div>

        <button onClick={() => onStart(playerTeam, cpuTeam, difficulty)}
          style={{ width:"100%", marginTop:24, background:"#f5c842", border:"none", borderRadius:8, padding:"14px", fontFamily:"Oswald,sans-serif", fontSize:20, fontWeight:700, letterSpacing:4, color:"#06060f", cursor:"pointer", boxShadow:"0 0 30px rgba(245,200,66,0.4)" }}>
          ⚽ KICK OFF
        </button>
      </div>
    </div>
  );
}

function GamePanel() {
  const [gameStarted, setGameStarted] = useState(false);
  const [playerTeam, setPlayerTeam]   = useState(GAME_TEAMS[0]);
  const [cpuTeam, setCpuTeam]         = useState(GAME_TEAMS[4]);
  const [difficulty, setDifficulty]   = useState(DIFFICULTIES[1]);

  function handleStart(pt, ct, diff) {
    setPlayerTeam(pt); setCpuTeam(ct); setDifficulty(diff); setGameStarted(true);
  }

  if (!gameStarted) return <TeamPicker onStart={handleStart} />;
  return <GameCanvas playerTeam={playerTeam} cpuTeam={cpuTeam} difficulty={difficulty} onBack={() => setGameStarted(false)} />;
}

function GameCanvas({ playerTeam, cpuTeam, difficulty, onBack }) {
  const diff = difficulty || DIFFICULTIES[1];
  const canvasRef = useRef(null);
  const sRef = useRef(initState());
  const keysRef = useRef({});
  const rafRef = useRef(null);
  const timerRef = useRef(null);
  const [ui, setUi] = useState({ score: { p: 0, ai: 0 }, time: 60, phase: "play", goalMsg: "" });

  const reset = useCallback((s) => { s.ball = mkBall(); s.player = mkHead("left"); s.ai = mkHead("right"); s.phase = "play"; }, []);

  const tick = useCallback(() => {
    const s = sRef.current;
    if (s.phase === "over") return;
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    const k = keysRef.current;

    if (s.phase === "play") {
      if (k["ArrowLeft"] || k["a"]) { s.player.vx = -MOVE_SPEED; s.player.facingRight = false; }
      else if (k["ArrowRight"] || k["d"]) { s.player.vx = MOVE_SPEED; s.player.facingRight = true; }
      else s.player.vx *= 0.6;
      // Jump: ↑ or W only — track double-tap for bicycle kick
      const jumpPressed = k["ArrowUp"] || k["w"];
      if (jumpPressed && !s.player._jumpWasHeld) {
        s.player._jumpWasHeld = true;
        const now = Date.now();
        if (s.player.onGround) {
          // First jump from ground
          s.player.vy = JUMP_FORCE;
          s.player.onGround = false;
          s.player.jumpCount = 1;
          s.player.lastJumpTime = now;
        } else if (!s.player.onGround && s.player.jumpCount >= 1 && (now - s.player.lastJumpTime) < 500) {
          // Double-tap in air — trigger bicycle kick if ball is airborne
          const b = s.ball;
          const ballAirborne = b.y < GROUND - BALL_R - 20;
          const ballNear = dst({ x: s.player.x, y: s.player.y }, b) < 110;
          if (ballAirborne && ballNear) {
            // Bicycle kick! Flip upward with spin
            s.player.vy = JUMP_FORCE * 0.7;
            s.player.bikeKick = 40; // animation frames
            s.player.jumpCount = 0;
            // Kick ball hard in OPPOSITE horizontal direction (classic bicycle kick)
            const kickDir = s.player.facingRight ? -1 : 1;
            b.vx = kickDir * 13;
            b.vy = -11;
            b.spin = b.vx * 0.12;
            s.shake = 14;
            s.particles.push(...mkParticles(b.x, b.y, playerTeam.c1, 25));
            setUi(u => ({ ...u, goalMsg: "🤸 BICYCLE KICK!" }));
            setTimeout(() => setUi(u => ({ ...u, goalMsg: "" })), 1200);
          } else {
            s.player.jumpCount = 0;
          }
        }
      } else if (!jumpPressed) {
        s.player._jumpWasHeld = false;
      }
      // Tick down bike kick animation
      if (s.player.bikeKick > 0) s.player.bikeKick--;
      // Power shot: hold Space to charge, release fires
      if (k[" "]) {
        s.player.powerCharge = Math.min(1, s.player.powerCharge + 0.025); // ~40 frames to full charge
        s.player.powerFired = false;
      } else if (s.player.powerCharge > 0 && !s.player.powerFired) {
        // Fire on release
        const b = s.ball;
        const px = s.player.x, py = s.player.y;
        const bDist = dst({ x: px, y: py + 12 }, b); // check torso distance
        if (bDist < 80) { // ball must be reasonably close
          const charge = s.player.powerCharge;
          const dir = s.player.facingRight ? 1 : -1;
          // Aim toward opponent's goal with slight upward angle
          const shotVx = dir * (8 + charge * 9);
          const shotVy = -3 - charge * 5;
          b.vx = shotVx;
          b.vy = shotVy;
          b.spin = shotVx * 0.1;
          s.shake = charge > 0.6 ? 12 : 6;
          s.particles.push(...mkParticles(b.x, b.y, playerTeam.c1, charge > 0.7 ? 20 : 10));
        }
        s.player.powerFired = true;
        s.player.powerCharge = 0;
      } else if (!k[" "]) {
        s.player.powerCharge = 0;
      }

      // Rainbow flick: press R when ball is near feet — chip the ball up and over your head backward
      if (k["r"] && !s.player.rainbowWasHeld) {
        s.player.rainbowWasHeld = true;
        const b = s.ball;
        const footX = s.player.x, footY = s.player.y + 52;
        const distToFeet = dst({ x: footX, y: footY }, b);
        if (distToFeet < 55 && b.y > GROUND - 100) {
          // Flick ball back over the player's head — backward and high
          const flickDir = s.player.facingRight ? -1 : 1; // opposite direction
          b.vx = flickDir * 3.5;
          b.vy = -13;
          b.spin = b.vx * 0.15;
          s.player.rainbowFlick = 30;
          s.particles.push(...mkParticles(b.x, b.y, "#a855f7", 18));
          setUi(u => ({ ...u, goalMsg: "🌈 RAINBOW FLICK!" }));
          setTimeout(() => setUi(u => ({ ...u, goalMsg: "" })), 1200);
        }
      } else if (!k["r"]) {
        s.player.rainbowWasHeld = false;
      }
      if (s.player.rainbowFlick > 0) s.player.rainbowFlick--;

      const b = s.ball, ai = s.ai;
      const predX = b.x + b.vx * diff.aiPredictFrames;
      let targetX;
      if (b.vx > 0 || b.x > GW * 0.55) {
        targetX = clamp(predX + 10, GW / 2 + HEAD_R, GW - GOAL_W - HEAD_R);
      } else {
        targetX = clamp(GW * 0.72, GW / 2 + HEAD_R, GW - GOAL_W - HEAD_R);
      }
      const aiMaxSpeed = MOVE_SPEED * diff.aiSpeed;
      ai.vx = ai.vx + ((targetX - ai.x) * diff.aiReaction - ai.vx) * 0.22;
      ai.vx = clamp(ai.vx, -aiMaxSpeed, aiMaxSpeed);
      ai.facingRight = ai.x < b.x;
      const ballAbove = b.y < GROUND - 60;
      const ballClose = Math.abs(b.x - ai.x) < diff.aiJumpRange;
      const ballIncoming = b.vx > 2 && b.x < ai.x + diff.aiJumpRange * 0.8;
      if (ai.onGround && ballClose && (ballAbove || ballIncoming)) {
        ai.vy = JUMP_FORCE * 0.9;
        ai.onGround = false;
      }

      [s.player, s.ai].forEach(h => {
        h.vy += GRAVITY; h.x += h.vx; h.y += h.vy;
        if (h.y >= GROUND - 70) { h.y = GROUND - 70; h.vy = 0; h.onGround = true; }
        if (h.y - HEAD_R < CEIL) { h.y = CEIL + HEAD_R; h.vy = Math.abs(h.vy) * 0.5; }
        h.x = clamp(h.x, GOAL_W + HEAD_R, GW - GOAL_W - HEAD_R);
      });
      s.player.x = clamp(s.player.x, GOAL_W + HEAD_R, GW / 2 - HEAD_R);
      s.ai.x = clamp(s.ai.x, GW / 2 + HEAD_R, GW - GOAL_W - HEAD_R);

      b.vy += GRAVITY * diff.gravityMult; b.x += b.vx * diff.ballSpeedMult; b.y += b.vy;
      b.vx *= BALL_FRICTION; b.spin += b.vx * 0.012; b.spin *= 0.97;

      // ── Full body collision ──────────────────────────────────────────
      // Each player has 3 hit zones relative to h.x, h.y (head anchor):
      //   HEAD:  h.x, h.y-24          r=26  → lifts ball upward
      //   TORSO: h.x, h.y+12          r=18  → medium arc
      //   LEGS:  h.x, h.y+52          r=16  → lower, rolls/chip
      [s.player, s.ai].forEach((h, pi) => {
        const col = pi === 0 ? playerTeam.c1 : cpuTeam.c1;
        const zones = [
          { ox: 0, oy: -24, r: 26, liftBias: -4.5, pwr: 0.85 }, // head
          { ox: 0, oy:  12, r: 18, liftBias: -3.0, pwr: 0.75 }, // torso
          { ox: 0, oy:  52, r: 16, liftBias: -1.2, pwr: 0.65 }, // legs/feet
        ];
        for (const z of zones) {
          const zx = h.x + z.ox, zy = h.y + z.oy;
          const d = dst({ x: zx, y: zy }, b);
          const minD = z.r + BALL_R;
          if (d < minD) {
            // Push ball out of zone first
            const angle = Math.atan2(b.y - zy, b.x - zx);
            b.x = zx + Math.cos(angle) * (minD + 1);
            b.y = zy + Math.sin(angle) * (minD + 1);

            // Relative velocity
            const relVx = b.vx - h.vx;
            const relVy = b.vy - h.vy;
            const relSpeed = Math.hypot(relVx, relVy);

            // Reflect relative velocity along normal, add player momentum + lift
            const nx = Math.cos(angle), ny = Math.sin(angle);
            const dot = relVx * nx + relVy * ny;
            // Only bounce if ball is moving toward zone
            if (dot < 0) {
              const restitution = 0.72;
              b.vx = (b.vx - (1 + restitution) * dot * nx) * z.pwr + h.vx * 0.4;
              b.vy = (b.vy - (1 + restitution) * dot * ny) * z.pwr + h.vy * 0.3 + z.liftBias;
              // Clamp max speed so nothing flies too fast
              const spd = Math.hypot(b.vx, b.vy);
              const maxSpd = 11;
              if (spd > maxSpd) { b.vx = b.vx / spd * maxSpd; b.vy = b.vy / spd * maxSpd; }
              b.spin = b.vx * 0.07;
              s.particles.push(...mkParticles(b.x, b.y, col, 6));
            }
            break; // only one zone per frame per player
          }
        }
      });

      if (b.y + BALL_R >= GROUND) { b.y = GROUND - BALL_R; b.vy = -Math.abs(b.vy) * BALL_BOUNCE; b.vx *= 0.80; if (Math.abs(b.vy) < 0.8) b.vy = 0; }
      if (b.y - BALL_R < CEIL) { b.y = CEIL + BALL_R; b.vy = Math.abs(b.vy) * 0.55; }

      // ── Crossbar collision — ball must enter below the crossbar to score ──
      // Left goal crossbar: x < GOAL_W, y == GROUND - GOAL_H
      if (b.x - BALL_R < GOAL_W && b.y - BALL_R <= GROUND - GOAL_H) {
        b.y = GROUND - GOAL_H + BALL_R + 1;
        b.vy = Math.abs(b.vy) * 0.6;
        b.x = GOAL_W + BALL_R + 1; b.vx = Math.abs(b.vx) * 0.6;
      }
      // Right goal crossbar: x > GW - GOAL_W, y == GROUND - GOAL_H
      if (b.x + BALL_R > GW - GOAL_W && b.y - BALL_R <= GROUND - GOAL_H) {
        b.y = GROUND - GOAL_H + BALL_R + 1;
        b.vy = Math.abs(b.vy) * 0.6;
        b.x = GW - GOAL_W - BALL_R - 1; b.vx = -Math.abs(b.vx) * 0.6;
      }

      if (b.x - BALL_R < 0) {
        if (b.y + BALL_R > GROUND - GOAL_H && b.y < GROUND) {
          s.score.ai++; s.particles.push(...mkParticles(20, b.y, cpuTeam.c1, 35)); s.shake = 20; s.phase = "goal";
          setUi(u => ({ ...u, score: { ...s.score }, phase: "goal", goalMsg: "😬 CPU SCORES!" }));
          setTimeout(() => { reset(s); setUi(u => ({ ...u, phase: "play", goalMsg: "" })); }, 2100);
        } else { b.x = BALL_R + 1; b.vx = Math.abs(b.vx) * 0.65; }
      }
      if (b.x + BALL_R > GW) {
        if (b.y + BALL_R > GROUND - GOAL_H && b.y < GROUND) {
          s.score.p++; s.particles.push(...mkParticles(GW - 20, b.y, playerTeam.c1, 35)); s.shake = 20; s.phase = "goal";
          setUi(u => ({ ...u, score: { ...s.score }, phase: "goal", goalMsg: "⚽ YOU SCORE!" }));
          setTimeout(() => { reset(s); setUi(u => ({ ...u, phase: "play", goalMsg: "" })); }, 2100);
        } else { b.x = GW - BALL_R - 1; b.vx = -Math.abs(b.vx) * 0.65; }
      }
    }

    s.particles = s.particles.map(p => ({ ...p, x: p.x + p.vx, y: p.y + p.vy, vy: p.vy + 0.18, life: p.life - p.decay })).filter(p => p.life > 0);
    if (s.shake > 0) s.shake = Math.max(0, s.shake - 1.2);
    const sx = s.shake > 0 ? (Math.random() - 0.5) * s.shake * 0.4 : 0;
    const sy = s.shake > 0 ? (Math.random() - 0.5) * s.shake * 0.4 : 0;
    ctx.save(); ctx.translate(sx, sy);
    drawScene(ctx, s);
    drawBall(ctx, s.ball);
    drawPlayer(ctx, s.player, true,  playerTeam.c1, playerTeam.c2, playerTeam.abbr);
    drawPlayer(ctx, s.ai,     false, cpuTeam.c1,    cpuTeam.c2,    cpuTeam.abbr);
    drawParticles(ctx, s.particles);
    // Power charge bar above player
    if (s.player.powerCharge > 0) {
      const bw = 48, bh = 7;
      const bx = s.player.x - bw / 2, by = s.player.y - 58;
      ctx.fillStyle = "rgba(0,0,0,0.55)";
      ctx.beginPath(); ctx.roundRect(bx - 1, by - 1, bw + 2, bh + 2, 4); ctx.fill();
      // Colour shifts yellow → orange → red as charge increases
      const r = Math.round(255);
      const g = Math.round(200 * (1 - s.player.powerCharge));
      ctx.fillStyle = `rgb(${r},${g},0)`;
      ctx.beginPath(); ctx.roundRect(bx, by, bw * s.player.powerCharge, bh, 3); ctx.fill();
      // "POWER" label
      ctx.fillStyle = "#fff"; ctx.font = "bold 8px 'Courier New',monospace";
      ctx.textAlign = "center"; ctx.textBaseline = "middle";
      ctx.fillText("POWER", s.player.x, by - 6);
    }
    if (s.phase === "goal") { ctx.fillStyle = s.goalMsg && s.goalMsg.includes("CPU") ? "rgba(180,30,30,0.15)" : "rgba(245,200,66,0.15)"; ctx.fillRect(-10, -10, GW + 20, GH + 20); }
    ctx.restore();
    rafRef.current = requestAnimationFrame(tick);
  }, [reset]);

  const startTimer = useCallback(() => {
    clearInterval(timerRef.current);
    timerRef.current = setInterval(() => {
      const s = sRef.current;
      if (s.phase === "over") return;
      if (s.phase === "play") {
        s.time = Math.max(0, s.time - 1);
        setUi(u => ({ ...u, time: s.time }));
        if (s.time <= 0) { s.phase = "over"; cancelAnimationFrame(rafRef.current); setUi(u => ({ ...u, phase: "over" })); }
      }
    }, 1000);
  }, []);

  useEffect(() => {
    const onKey = e => { if ([" ","ArrowUp","ArrowDown","ArrowLeft","ArrowRight"].includes(e.key)) e.preventDefault(); keysRef.current[e.key] = e.type === "keydown"; };
    window.addEventListener("keydown", onKey); window.addEventListener("keyup", onKey);
    rafRef.current = requestAnimationFrame(tick); startTimer();
    return () => { window.removeEventListener("keydown", onKey); window.removeEventListener("keyup", onKey); cancelAnimationFrame(rafRef.current); clearInterval(timerRef.current); };
  }, [tick, startTimer]);

  function restart() {
    cancelAnimationFrame(rafRef.current); clearInterval(timerRef.current);
    sRef.current = initState(); setUi({ score: { p: 0, ai: 0 }, time: 60, phase: "play", goalMsg: "" });
    rafRef.current = requestAnimationFrame(tick); startTimer();
  }

  const isOver = ui.phase === "over";
  const winner = ui.score.p > ui.score.ai ? "YOU WIN! 🏆" : ui.score.p < ui.score.ai ? "CPU WINS 🤖" : "DRAW 🤝";
  const timeColor = ui.time <= 10 ? "#ff4444" : ui.time <= 20 ? "#ffaa00" : "#f5c842";

  return (
    <div>
      <div style={{ display: "grid", gridTemplateColumns: "1fr auto 1fr", background: "linear-gradient(135deg,#100820,#1a1030)", border: "2px solid #f5c84233", borderRadius: 10, padding: "12px 20px", marginBottom: 12, alignItems: "center" }}>
        <div style={{ textAlign: "center" }}>
          <div style={{ width: 38, height: 38, borderRadius: "50%", background: `linear-gradient(135deg,${playerTeam.c1},${playerTeam.c2})`, margin: "0 auto 5px", border: "2px solid rgba(255,255,255,0.15)", boxShadow: `0 0 14px ${playerTeam.c1}66` }} />
          <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 13, fontWeight: 700, color: playerTeam.c1, letterSpacing: 1, marginBottom: 2, textShadow: `0 0 10px ${playerTeam.c1}88` }}>{playerTeam.name}</div>
          <div style={{ fontSize: 54, lineHeight: 1, color: playerTeam.c1, textShadow: `0 0 20px ${playerTeam.c1}44` }}>{ui.score.p}</div>
          <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 10, color: "#444", marginTop: 2 }}>← attacks right →</div>
        </div>
        <div style={{ textAlign: "center", padding: "0 16px" }}>
          <div style={{ fontSize: ui.time <= 10 ? 20 : 14, fontFamily: "Barlow Condensed,sans-serif", fontWeight: 700, color: timeColor, animation: ui.time <= 10 ? "pulse .8s infinite" : "none", letterSpacing: 2 }}>⏱ {ui.time}s</div>
          {ui.goalMsg ? <div style={{ fontSize: 16, fontFamily: "Barlow Condensed,sans-serif", fontWeight: 700, color: ui.goalMsg.includes("CPU") ? cpuTeam.c1 : ui.goalMsg.includes("RAINBOW") ? "#a855f7" : playerTeam.c1, marginTop: 6, animation: "goalBang .4s ease-out" }}>{ui.goalMsg}</div>
            : <div style={{ color: "#333", fontSize: 20, marginTop: 6, letterSpacing: 4 }}>VS</div>}
          <div style={{ marginTop: 6, fontFamily:"Barlow Condensed,sans-serif", fontSize:10, fontWeight:700, color: diff.color, letterSpacing:1, opacity:0.8 }}>{diff.label}</div>
        </div>
        <div style={{ textAlign: "center" }}>
          <div style={{ width: 38, height: 38, borderRadius: "50%", background: `linear-gradient(135deg,${cpuTeam.c1},${cpuTeam.c2})`, margin: "0 auto 5px", border: "2px solid rgba(255,255,255,0.15)", boxShadow: `0 0 14px ${cpuTeam.c1}66` }} />
          <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 13, fontWeight: 700, color: cpuTeam.c1, letterSpacing: 1, marginBottom: 2, textShadow: `0 0 10px ${cpuTeam.c1}88` }}>{cpuTeam.name}</div>
          <div style={{ fontSize: 54, lineHeight: 1, color: cpuTeam.c1, textShadow: `0 0 20px ${cpuTeam.c1}44` }}>{ui.score.ai}</div>
          <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 10, color: "#444", marginTop: 2 }}>← attacks left →</div>
        </div>
      </div>
      <div style={{ position: "relative", borderRadius: 10, overflow: "hidden", border: "2px solid #f5c84222", boxShadow: "0 0 50px rgba(245,200,66,0.07)" }}>
        <canvas ref={canvasRef} width={GW} height={GH} style={{ display: "block", width: "100%" }} />
        {isOver && (
          <div style={{ position: "absolute", inset: 0, background: "rgba(4,4,14,0.92)", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", gap: 12, animation: "fadeIn .5s" }}>
            <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 12, color: "#555", letterSpacing: 4 }}>FULL TIME</div>
            <div style={{ fontSize: 46, color: "#f5c842", letterSpacing: 3, textShadow: "0 0 30px #f5c84266" }}>{winner}</div>
            <div style={{ display:"flex", alignItems:"center", gap:16, fontSize: 36, letterSpacing: 6 }}>
              <span style={{ color: playerTeam.c1 }}>{ui.score.p}</span>
              <span style={{ color:"#333", fontSize:20 }}>—</span>
              <span style={{ color: cpuTeam.c1 }}>{ui.score.ai}</span>
            </div>
            <div style={{ fontFamily:"Barlow Condensed,sans-serif", fontSize:13, color:"#555" }}>{playerTeam.name} vs {cpuTeam.name}</div>
            <div style={{ display:"flex", gap:10, marginTop:8 }}>
              <button onClick={restart} style={{ background: "#f5c842", border: "none", color: "#06060f", fontFamily: "Oswald,sans-serif", fontSize: 16, letterSpacing: 3, padding: "11px 32px", borderRadius: 6, cursor: "pointer", fontWeight: 700 }}>↺ REMATCH</button>
              <button onClick={onBack} style={{ background: "transparent", border: "1px solid #f5c84255", color: "#f5c842", fontFamily: "Oswald,sans-serif", fontSize: 16, letterSpacing: 2, padding: "11px 24px", borderRadius: 6, cursor: "pointer" }}>⬅ TEAMS</button>
            </div>
          </div>
        )}
      </div>
      <div style={{ marginTop: 10, display: "grid", gridTemplateColumns: "1fr 1fr 1fr 1fr 1fr auto auto", background: "#0c0c1e", borderRadius: 8, overflow: "hidden", border: "1px solid #1a1a3e" }}>
        {[["← → / A D","Move"],["↑ / W","Jump"],["↑ / W (×2 in air)","Bicycle Kick 🤸"],["SPACE (hold)","Power Shot 💥"],["R (near ball)","Rainbow Flick 🌈"]].map(([k,v]) => (
          <div key={k} style={{ padding: "9px 10px", textAlign: "center", borderRight: "1px solid #1a1a3e" }}>
            <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 12, color: "#f5c842", letterSpacing: 0.5, marginBottom: 2 }}>{k}</div>
            <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, color: "#555" }}>{v}</div>
          </div>
        ))}
        <div style={{ padding: "8px 10px", display: "flex", alignItems: "center", borderRight: "1px solid #1a1a3e" }}>
          <button onClick={restart} style={{ background: "transparent", border: "1px solid #f5c84244", color: "#f5c842", fontFamily: "Oswald,sans-serif", fontSize: 13, padding: "5px 12px", borderRadius: 4, cursor: "pointer" }}>↺</button>
        </div>
        <div style={{ padding: "8px 10px", display: "flex", alignItems: "center" }}>
          <button onClick={onBack} style={{ background: "transparent", border: "1px solid #55555544", color: "#555", fontFamily: "Oswald,sans-serif", fontSize: 13, padding: "5px 12px", borderRadius: 4, cursor: "pointer" }}>⬅ Teams</button>
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════════
// TEAM NAME HELPER — special styling for certain clubs
// ═══════════════════════════════════════════════════════════════════════
function TeamName({ name, size = 15, align = "left" }) {
  const isPoo      = name.includes("Tottenham") || name.includes("Brighton");
  const isStar     = name.includes("Liverpool");
  const color = isPoo ? "#7B3F00" : isStar ? "#f5c842" : "#eee";
  const prefix = isPoo
    ? <span style={{ marginRight: 4, fontSize: size - 1 }}>💩</span>
    : isStar
    ? <span style={{ marginRight: 4, fontSize: size - 1, animation: "blink 1s step-start infinite" }}>⭐</span>
    : null;
  return (
    <span style={{ color, fontWeight: 600, display: "inline-flex", alignItems: "center", justifyContent: align === "right" ? "flex-end" : "flex-start", width: "100%" }}>
      {prefix}{name}
    </span>
  );
}

// ═══════════════════════════════════════════════════════════════════════
// TEAM PROFILE MODAL
// ═══════════════════════════════════════════════════════════════════════
function TeamProfile({ team, league, onClose }) {
  const [tab, setTab] = useState("stats");
  const gp = team.w + team.d + team.l;
  const winPct = gp ? Math.round(team.w / gp * 100) : 0;
  const drawPct = gp ? Math.round(team.d / gp * 100) : 0;
  const lossPct = gp ? Math.round(team.l / gp * 100) : 0;
  const pts_per_game = gp ? (team.pts / gp).toFixed(2) : "0.00";

  const past = league.recent.filter(g => g.h === team.name || g.a === team.name);
  const upcoming = league.upcoming.filter(g => g.h === team.name || g.a === team.name);

  // derive form from past fixtures (most recent last in array = most recent)
  const form = [...past].reverse().slice(0, 5).map(g => {
    const isHome = g.h === team.name;
    const tf = isHome ? g.hs : g.as;
    const of = isHome ? g.as : g.hs;
    return tf > of ? "W" : tf < of ? "L" : "D";
  });

  const formColor = r => r === "W" ? "#3ecf5a" : r === "L" ? "#ff6b6b" : "#f5c842";

  function StatBar({ label, val, max, color = "#f5c842" }) {
    return (
      <div style={{ marginBottom: 12 }}>
        <div style={{ display: "flex", justifyContent: "space-between", fontFamily: "Barlow Condensed,sans-serif", fontSize: 13, marginBottom: 4 }}>
          <span style={{ color: "#888" }}>{label}</span>
          <span style={{ color, fontWeight: 700 }}>{val}</span>
        </div>
        <div style={{ height: 6, background: "#0f0f1f", borderRadius: 3, overflow: "hidden" }}>
          <div style={{ width: `${Math.min(100, (val / max) * 100)}%`, height: "100%", background: color, borderRadius: 3, transition: "width .6s ease" }} />
        </div>
      </div>
    );
  }

  return (
    <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.85)", zIndex: 1000, display: "flex", alignItems: "center", justifyContent: "center", padding: 16, animation: "fadeIn .2s" }}
      onClick={e => e.target === e.currentTarget && onClose()}>
      <div style={{ background: "#0c0c1e", border: `2px solid ${league.color}55`, borderRadius: 12, width: "100%", maxWidth: 520, maxHeight: "88vh", overflow: "hidden", display: "flex", flexDirection: "column", boxShadow: `0 0 60px ${league.color}33` }}>

        {/* Header */}
        <div style={{ background: `linear-gradient(135deg,${league.color}88,#0c0c1e)`, padding: "18px 20px", display: "flex", alignItems: "center", justifyContent: "space-between", flexShrink: 0 }}>
          <div>
            <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, color: "rgba(255,255,255,0.4)", letterSpacing: 3, marginBottom: 3 }}>{league.flag} {league.name.toUpperCase()}</div>
            <div style={{ fontSize: 26, fontWeight: 700, letterSpacing: 2, display: "flex", alignItems: "center", gap: 6 }}>
              <TeamName name={team.name} size={24} />
            </div>
            <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 13, color: "rgba(255,255,255,0.5)", marginTop: 4 }}>
              Rank #{team.rank} · {team.pts} pts · {gp} games played
            </div>
          </div>
          <button onClick={onClose} style={{ background: "rgba(255,255,255,0.07)", border: "1px solid rgba(255,255,255,0.12)", color: "#aaa", width: 34, height: 34, borderRadius: "50%", cursor: "pointer", fontSize: 18, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>✕</button>
        </div>

        {/* Form strip */}
        {form.length > 0 && (
          <div style={{ padding: "10px 20px", background: "#07070e", display: "flex", alignItems: "center", gap: 8, borderBottom: "1px solid #1a1a3e", flexShrink: 0 }}>
            <span style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, color: "#555", letterSpacing: 2, marginRight: 4 }}>FORM</span>
            {form.map((r, i) => (
              <div key={i} style={{ width: 28, height: 28, borderRadius: 4, background: formColor(r), display: "flex", alignItems: "center", justifyContent: "center", fontFamily: "Oswald,sans-serif", fontSize: 13, fontWeight: 700, color: "#06060f" }}>{r}</div>
            ))}
          </div>
        )}

        {/* Sub tabs */}
        <div style={{ display: "flex", borderBottom: "1px solid #1a1a3e", flexShrink: 0 }}>
          {[["stats","📊 Stats"],["past","✅ Past Fixtures"],["upcoming","📅 Upcoming"]].map(([t, l]) => (
            <button key={t} onClick={() => setTab(t)} style={{ flex: 1, padding: "11px 6px", fontFamily: "Oswald,sans-serif", fontSize: 13, letterSpacing: 1, cursor: "pointer", background: "transparent", color: tab === t ? "#f5c842" : "#555", border: "none", borderBottom: `2px solid ${tab === t ? "#f5c842" : "transparent"}`, transition: "all .15s" }}>{l}</button>
          ))}
        </div>

        {/* Content */}
        <div style={{ overflowY: "auto", padding: "18px 20px", flex: 1 }}>

          {/* STATS */}
          {tab === "stats" && (
            <div>
              {/* Summary cards */}
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr 1fr", gap: 8, marginBottom: 20 }}>
                {[["PTS", team.pts, "#f5c842"], ["W", team.w, "#3ecf5a"], ["D", team.d, "#888"], ["L", team.l, "#ff6b6b"]].map(([lbl, val, col]) => (
                  <div key={lbl} style={{ background: "#07070e", borderRadius: 8, padding: "12px 8px", textAlign: "center", border: `1px solid ${col}22` }}>
                    <div style={{ fontFamily: "Oswald,sans-serif", fontSize: 28, fontWeight: 700, color: col }}>{val}</div>
                    <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, color: "#555", letterSpacing: 2, marginTop: 2 }}>{lbl}</div>
                  </div>
                ))}
              </div>

              <StatBar label="Points per game" val={pts_per_game} max={3} color="#f5c842" />
              <StatBar label="Win rate" val={`${winPct}%`} max={100} color="#3ecf5a" />
              <StatBar label="Draw rate" val={`${drawPct}%`} max={100} color="#888" />
              <StatBar label="Loss rate" val={`${lossPct}%`} max={100} color="#ff6b6b" />
              <StatBar label="Games played" val={gp} max={38} color={league.color || "#f5c842"} />

              <div style={{ marginTop: 16, padding: 14, background: "#07070e", borderRadius: 8, border: "1px solid #1a1a3e" }}>
                <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, color: "#555", letterSpacing: 2, marginBottom: 10 }}>SEASON AT A GLANCE</div>
                <div style={{ display: "flex", height: 20, borderRadius: 4, overflow: "hidden" }}>
                  <div style={{ width: `${winPct}%`, background: "#3ecf5a" }} />
                  <div style={{ width: `${drawPct}%`, background: "#555" }} />
                  <div style={{ width: `${lossPct}%`, background: "#ff6b6b" }} />
                </div>
                <div style={{ display: "flex", gap: 14, marginTop: 8, fontFamily: "Barlow Condensed,sans-serif", fontSize: 12 }}>
                  <span style={{ color: "#3ecf5a" }}>● {team.w} Wins</span>
                  <span style={{ color: "#888" }}>● {team.d} Draws</span>
                  <span style={{ color: "#ff6b6b" }}>● {team.l} Losses</span>
                </div>
              </div>
            </div>
          )}

          {/* PAST FIXTURES */}
          {tab === "past" && (
            past.length === 0
              ? <div style={{ textAlign: "center", color: "#555", fontFamily: "Barlow Condensed,sans-serif", padding: 40 }}>No recent fixtures found</div>
              : past.map((g, i) => {
                const isHome = g.h === team.name;
                const hw = g.hs > g.as, aw = g.as > g.hs;
                const won = isHome ? hw : aw;
                const drew = g.hs === g.as;
                const result = drew ? "D" : won ? "W" : "L";
                const resColor = drew ? "#f5c842" : won ? "#3ecf5a" : "#ff6b6b";
                return (
                  <div key={i} style={{ background: "#07070e", borderRadius: 7, padding: "10px 14px", marginBottom: 8, borderLeft: `3px solid ${resColor}`, animation: `fadeIn .2s ${i * .05}s both` }}>
                    <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 10, color: "#444", marginBottom: 5 }}>{g.d} · {isHome ? "Home" : "Away"}</div>
                    <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                      <span style={{ flex: 1, fontFamily: "Barlow Condensed,sans-serif", fontSize: 15, color: hw ? "#fff" : "#666", textAlign: "right" }}><TeamName name={g.h} size={15} align="right" /></span>
                      <div style={{ display: "flex", gap: 5, alignItems: "center", padding: "3px 10px", background: "#0c0c1e", borderRadius: 5, minWidth: 58, justifyContent: "center" }}>
                        <span style={{ fontSize: 18, color: hw ? "#3ecf5a" : "#e0e0e0" }}>{g.hs}</span>
                        <span style={{ color: "#333", fontSize: 10 }}>—</span>
                        <span style={{ fontSize: 18, color: aw ? "#3ecf5a" : "#e0e0e0" }}>{g.as}</span>
                      </div>
                      <span style={{ flex: 1, fontFamily: "Barlow Condensed,sans-serif", fontSize: 15, color: aw ? "#fff" : "#666" }}><TeamName name={g.a} size={15} /></span>
                      <div style={{ width: 24, height: 24, borderRadius: 4, background: resColor, display: "flex", alignItems: "center", justifyContent: "center", fontFamily: "Oswald,sans-serif", fontSize: 12, fontWeight: 700, color: "#06060f", flexShrink: 0 }}>{result}</div>
                    </div>
                  </div>
                );
              })
          )}

          {/* UPCOMING FIXTURES */}
          {tab === "upcoming" && (
            upcoming.length === 0
              ? <div style={{ textAlign: "center", color: "#555", fontFamily: "Barlow Condensed,sans-serif", padding: 40 }}>No upcoming fixtures scheduled</div>
              : upcoming.map((g, i) => {
                const isHome = g.h === team.name;
                const opponent = isHome ? g.a : g.h;
                const homeProb = g.ph, drawProb = g.pd, awayProb = g.pa;
                const teamWinProb = isHome ? homeProb : awayProb;
                return (
                  <div key={i} style={{ background: "#07070e", borderRadius: 7, padding: "12px 14px", marginBottom: 8, borderLeft: `3px solid ${league.color}`, animation: `fadeIn .2s ${i * .05}s both` }}>
                    <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 10, color: "#444", marginBottom: 6 }}>📅 {g.d} · {isHome ? "Home" : "Away"}</div>
                    <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: homeProb ? 10 : 0 }}>
                      <span style={{ flex: 1, fontFamily: "Barlow Condensed,sans-serif", fontSize: 16, color: isHome ? "#fff" : "#777", textAlign: "right" }}><TeamName name={g.h} size={16} align="right" /></span>
                      <span style={{ padding: "2px 10px", fontFamily: "Oswald,sans-serif", fontSize: 11, color: "#f5c842", background: "#0c0c1e", borderRadius: 3 }}>VS</span>
                      <span style={{ flex: 1, fontFamily: "Barlow Condensed,sans-serif", fontSize: 16, color: !isHome ? "#fff" : "#777" }}><TeamName name={g.a} size={16} /></span>
                    </div>
                    {homeProb && (
                      <>
                        <div style={{ display: "flex", justifyContent: "space-between", fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, marginBottom: 4 }}>
                          <span style={{ color: "#3ecf5a" }}>H {homeProb}%</span>
                          <span style={{ color: "#888" }}>Draw {drawProb}%</span>
                          <span style={{ color: "#f5c842" }}>A {awayProb}%</span>
                        </div>
                        <div style={{ height: 5, borderRadius: 3, display: "flex", overflow: "hidden", marginBottom: 8 }}>
                          <div style={{ width: `${homeProb}%`, background: "#3ecf5a" }} />
                          <div style={{ width: `${drawProb}%`, background: "#333" }} />
                          <div style={{ width: `${awayProb}%`, background: "#f5c842" }} />
                        </div>
                        <div style={{ fontFamily: "Barlow Condensed,sans-serif", fontSize: 12, color: teamWinProb >= 50 ? "#3ecf5a" : "#888" }}>
                          {team.name} win probability: <strong style={{ color: teamWinProb >= 50 ? "#3ecf5a" : teamWinProb >= 35 ? "#f5c842" : "#ff6b6b" }}>{teamWinProb}%</strong>
                        </div>
                      </>
                    )}
                  </div>
                );
              })
          )}
        </div>
      </div>
    </div>
  );
}

