          {g.ph && <>
            <div style={{ display: "flex", justifyContent: "space-between", fontFamily: "Barlow Condensed,sans-serif", fontSize: 11, marginBottom: 4 }}>
              <span style={{ color: "#3ecf5a" }}>H {g.ph}%</span>
              <span style={{ color: "#888" }}>Draw {g.pd}%</span>
              <span style={{ color: "#f5c842" }}>A {g.pa}%</span>
            </div>
            <div style={{ height: 5, borderRadius: 3, display: "flex", overflow: "hidden" }}>
              <div style={{ width: `${g.ph}%`, background: "#3ecf5a" }} />
              <div style={{ width: `${g.pd}%`, background: "#333" }} />
              <div style={{ width: `${g.pa}%`, background: "#f5c842" }} />
            </div>
          </>}
        </div>
      ))}
    </div>
  );
}

